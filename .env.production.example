# Copia queste variabili nel pannello Environment Variables di Railway/Vercel

# Vercel Postgres (Neon) - ottieni la stringa dalla dashboard Vercel > Storage > Postgres
DATABASE_URL=postgres://user:password@host.neon.tech/lifewrapped?sslmode=require

# Steam API Key - https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# URL del frontend deployato su Vercel
ALLOWED_ORIGINS=https://your-app.vercel.app